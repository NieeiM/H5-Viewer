{
  "name": "vscode-h5-viewer",
  "displayName": "H5 Viewer",
  "publisher": "meijiahao",
  "description": "Visualize HDF5 files in VS Code with optimized remote support",
  "version": "1.7.1",
  "license": "GPL-3.0",
  "homepage": "https://github.com/NieeiM/H5-Viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/NieeiM/H5-Viewer.git"
  },
  "bugs": {
    "url": "https://github.com/NieeiM/H5-Viewer/issues"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#162841",
    "theme": "dark"
  },
  "categories": [
    "Visualization"
  ],
  "engines": {
    "vscode": ">=1.100.0"
  },
  "type": "module",
  "contributes": {
    "customEditors": [
      {
        "viewType": "h5viewer.viewer",
        "displayName": "H5 Viewer",
        "selector": [
          {
            "filenamePattern": "*.{h5,hdf,hdf5,hf5,nx,nxs,nx5,nexus,cxi,nc,nc4,loom,jld2,h5ebsd,edaxh5,oh5,dream3d,geoh5,h5oina,h5ad,mat,cnt,npy,safetensors,gguf}"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "h5viewer.fallback-viewer",
        "displayName": "H5 Viewer (any extension)",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "main": "./out/main.js",
  "scripts": {
    "build": "pnpm build:app && pnpm build:extension --minify && pnpm build:copy-h5wasm",
    "build:app": "vite build",
    "build:extension": "esbuild ./extension/index.ts --bundle --outfile=out/main.js --external:vscode --external:h5wasm --external:h5wasm/node --loader:.so=file --format=esm --platform=node",
    "build:copy-h5wasm": "node scripts/copy-h5wasm.js",
    "watch": "pnpm build:extension --sourcemap --watch",
    "lint": "pnpm \"/^lint:/\"",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:prettier": "prettier --cache --check .",
    "vscode:prepublish": "pnpm build",
    "pub": "pnpm --allow-build=@vscode/vsce-sign --allow-build=keytar dlx @vscode/vsce publish --no-dependencies",
    "pub:ovsx": "pnpm --allow-build=@vscode/vsce-sign --allow-build=keytar dlx ovsx publish --no-dependencies"
  },
  "dependencies": {
    "@h5web/app": "16.0.1",
    "@react-hookz/web": "25.1.1",
    "assert": "2.1.0",
    "h5wasm": "0.8.7",
    "h5wasm-plugins": "0.2.0",
    "mat-for-js": "1.1.0",
    "normalize.css": "8.0.1",
    "ooura": "2.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "6.0.0"
  },
  "devDependencies": {
    "@esrf/eslint-config": "1.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "~1.100.0",
    "@types/vscode-webview": "~1.57.5",
    "@vitejs/plugin-react-swc": "4.0.1",
    "esbuild": "0.27.0",
    "eslint": "9.38.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "vite": "7.2.2"
  }
}
